{
  "expo": {
    "name": "Workspace",
    "slug": "workspace",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "workspace",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0c11"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.workspace.app",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for drawing in notes.",
        "NSPhotoLibraryUsageDescription": "Used to attach images to notes.",
        "NSMicrophoneUsageDescription": "Used for audio notes."
      }
    },
    "android": {
      "package": "com.workspace.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0c0c11"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
