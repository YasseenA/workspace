# Copy this file to .env and fill in your values

# Anthropic API key — get from console.anthropic.com
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-...

# Clerk publishable key — get from dashboard.clerk.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# URL of your deployed canvas-proxy.js server (Railway / Render / Fly)
# Leave blank to use localhost:3001 for local dev
EXPO_PUBLIC_PROXY_URL=https://your-proxy.up.railway.app

# Supabase — get from supabase.com → project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
